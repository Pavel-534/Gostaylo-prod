{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/checkin-reminder",
      "schedule": "0 7 * * *"
    },
    {
      "path": "/api/cron/payouts",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/cron/cleanup-drafts",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/draft-digest",
      "schedule": "0 2 * * *"
    }
  ]
}
