# Copy to keystore.properties (same folder) and fill with release values.
# keystore.properties is gitignored — never commit real passwords.
#
# storeFile path is relative to mobile/android-twa/android/

storeFile=airento-release.keystore
storePassword=CHANGE_ME_STORE_PASSWORD
keyAlias=airento
keyPassword=CHANGE_ME_KEY_PASSWORD
